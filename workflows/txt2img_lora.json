{
  "_meta": {
    "workflow": "txt2img_lora",
    "version": "1.0.0",
    "description": "txt2img with LoRA loader for character consistency (Phase 3+).",
    "parameterized_nodes": {
      "4": {"field": "ckpt_name", "param": "{{checkpoint}}"},
      "10": {
        "lora_name": "{{lora_name}}",
        "strength_model": "{{lora_strength}}",
        "strength_clip": "{{lora_strength}}"
      },
      "6": {"field": "text", "param": "{{positive_prompt}}"},
      "7": {"field": "text", "param": "{{negative_prompt}}"},
      "3": {
        "seed": "{{seed}}",
        "steps": "{{steps}}",
        "cfg": "{{cfg}}",
        "sampler_name": "{{sampler}}",
        "scheduler": "{{scheduler}}"
      },
      "5": {"width": "{{width}}", "height": "{{height}}"}
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "illustriousXL_v01.safetensors"}
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "{{lora_name}}",
      "strength_model": 0.8,
      "strength_clip": 0.8,
      "model": ["4", 0],
      "clip": ["4", 1]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "{{positive_prompt}}", "clip": ["10", 1]}
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "{{negative_prompt}}", "clip": ["10", 1]}
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1}
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 42, "steps": 30, "cfg": 7.0,
      "sampler_name": "dpm++_2m", "scheduler": "karras", "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {"class_type": "VAEDecode", "inputs": {"samples": ["3", 0], "vae": ["4", 2]}},
  "9": {"class_type": "SaveImage", "inputs": {"images": ["8", 0], "filename_prefix": "vpipe_lora"}}
}
