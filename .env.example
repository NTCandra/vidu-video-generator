# ComfyUI server (Phase 1+)
COMFYUI_URL=http://127.0.0.1:8188

# Ollama server for local LLM (Phase 5+)
OLLAMA_URL=http://127.0.0.1:11434

# Anthropic API — optional, used when llm.backend: anthropic in pipeline.yaml
ANTHROPIC_API_KEY=

# Log format: "human" (default, colored rich output) or "json" (structured, for log aggregation)
LOG_FORMAT=human
